1.4 API Key Security Audit
[ ] Keys have restrictions - IP allowlists, domain restrictions, rate limits
[ ] Least privilege - Keys have minimum required permissions
[ ] Separate keys per environment - Dev, staging, production keys are different
[ ] Key monitoring - Usage tracking and anomaly detection enabled
[ ] Automated scanning - Tools like Gitleaks, TruffleHog in CI/CD
[ ] Revocation process - Documented procedure for compromised keys
[ ] No keys in client bundles - Check with grep -r "sk_" dist/ for exposed secrets

🛡️ 2. Supabase Row Level Security (RLS)
2.1 RLS Fundamentals
Why RLS is Critical
Database-level security - Protection even if API is bypassed
User isolation - Users can only access their own data
Admin access control - Granular permissions by role
Multi-tenant support - Secure data separation
2.2 RLS Audit Checklist
Critical Checks
[ ] RLS enabled on ALL public tables - No exposed tables without RLS

 -- Check for tables without RLS
SELECT tablename 
FROM pg_tables 
WHERE schemaname = 'public' 
AND tablename NOT IN (
  SELECT tablename 
  FROM pg_policies
);


[ ] Policies defined for all operations - SELECT, INSERT, UPDATE, DELETE


[ ] No bypassrls roles exposed - Service role keys never in client code


[ ] JWT claims used correctly - auth.uid() and auth.jwt() in policies


[ ] Storage bucket policies - RLS on storage.objects table


Example RLS Policies
-- Enable RLS
ALTER TABLE todos ENABLE ROW LEVEL SECURITY;

-- ✅ GOOD: Users can only see their own todos
CREATE POLICY "Users can view own todos"
ON todos
FOR SELECT
TO authenticated
USING (auth.uid() = user_id);

-- ✅ GOOD: Users can only insert their own todos
CREATE POLICY "Users can insert own todos"
ON todos
FOR INSERT
TO authenticated
WITH CHECK (auth.uid() = user_id);

-- ✅ GOOD: Users can update their own todos
CREATE POLICY "Users can update own todos"
ON todos
FOR UPDATE
TO authenticated
USING (auth.uid() = user_id)
WITH CHECK (auth.uid() = user_id);

-- ✅ GOOD: Users can delete their own todos
CREATE POLICY "Users can delete own todos"
ON todos
FOR DELETE
TO authenticated
USING (auth.uid() = user_id);

-- ✅ GOOD: Public read access for published content
CREATE POLICY "Anyone can view published posts"
ON posts
FOR SELECT
TO anon, authenticated
USING (status = 'published');

-- ✅ GOOD: Admin access
CREATE POLICY "Admins can do everything"
ON posts
FOR ALL
TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM user_roles
    WHERE user_id = auth.uid()
    AND role = 'admin'
  )
);

2.3 Common RLS Vulnerabilities
❌ Anti-Patterns to Flag
-- CRITICAL: No RLS enabled
-- Tables accessible to everyone without policies

-- CRITICAL: Overly permissive policy
CREATE POLICY "Public access to everything"
ON sensitive_data
FOR ALL
TO public  -- ❌ Never use 'public' role
USING (true);

-- CRITICAL: Using user_metadata for authorization
CREATE POLICY "Check user metadata"
ON data
FOR SELECT
USING (
  (auth.jwt() -> 'user_metadata' ->> 'role') = 'admin'  
  -- ❌ User can modify their own metadata!
);

-- BETTER: Use app_metadata
CREATE POLICY "Check app metadata"
ON data
FOR SELECT
USING (
  (auth.jwt() -> 'app_metadata' ->> 'role') = 'admin'
  -- ✅ Only admins can modify app_metadata
);

2.4 RLS Performance Optimization
-- ✅ Add indexes on columns used in policies
CREATE INDEX idx_todos_user_id ON todos(user_id);
CREATE INDEX idx_user_roles_user_id ON user_roles(user_id);

-- ✅ Use security definer functions for complex checks
CREATE OR REPLACE FUNCTION is_admin()
RETURNS boolean
LANGUAGE sql
SECURITY DEFINER
AS $$
  SELECT EXISTS (
    SELECT 1 FROM user_roles
    WHERE user_id = auth.uid()
    AND role = 'admin'
  );
$$;

-- Then use in policy
CREATE POLICY "Admin access"
ON sensitive_table
FOR ALL
TO authenticated
USING ((SELECT is_admin()));  -- ✅ Cached per query

-- ✅ Optimize join conditions
-- BAD (slow)
auth.uid() IN (
  SELECT user_id FROM team_users 
  WHERE team_users.team_id = table.team_id
)

-- GOOD (fast)
team_id IN (
  SELECT team_id FROM team_users 
  WHERE user_id = auth.uid()
)

2.5 Storage RLS (File Uploads)
-- Enable RLS on storage.objects
ALTER TABLE storage.objects ENABLE ROW LEVEL SECURITY;

-- ✅ Users can upload to their own folder
CREATE POLICY "Users can upload own files"
ON storage.objects
FOR INSERT
TO authenticated
WITH CHECK (
  bucket_id = 'avatars' 
  AND (storage.foldername(name))[1] = auth.uid()::text
);

-- ✅ Users can view their own files
CREATE POLICY "Users can view own files"
ON storage.objects
FOR SELECT
TO authenticated
USING (
  bucket_id = 'avatars' 
  AND (storage.foldername(name))[1] = auth.uid()::text
);

-- ✅ Public bucket for uploaded images
CREATE POLICY "Public images readable"
ON storage.objects
FOR SELECT
TO public
USING (bucket_id = 'public-images');

